## Example to fit a Special Pair Correlation Function (SPCF) involving a reactive species
## NOTE: the order of the directives is irrelevant.
## Specification about the input data
what_to_fit       spcf         # The input data corresponds to a Special Pair Correlation Function (SPCF) computed from 0 to 15 ps.
species_name      H3O+         # This is a string needed to label the reactive species (H3O+ in this case).
filename          SPCF_15ps    # Name of the file that contains the data

### Settings to instruct how data will be fitted
fitting_function  2exp_to_zero      # This instructs the code to use a bi-exponential decay. See notes for other possible options.
max_iterations 200                  # Number of maximum iterations for fitting
std_samples  9                      # Number of departures from the average values (AVG), starting from AVG-(max_times_std)*STD 
                                    # and generating 5 profiles up to AVG+(max_times_std)*STD, including the AVG values. 
                                    # By default, the set of raw data is printed to the RAW_DATA file. If this value is 1, only AVG is fitted 
                                    # (max_times_std is ignored)
                                     
max_times_std  0.3                  # Maximum times the STD values (see above)

start_time  0.00 ps                 # Data above  0.0 ps is considered. If not defined, the lowest recorded time is considered
end_time   15.00 ps                 # Data above 15.0 ps is considered. If not defined, the largest recorded time is considered   

ime_column_number  1               # Column number of the input file that reports time 
vg_column_number   2               # Column number of the input file that reports average values  
td_column_number   3               # Column number of the input file that reports STD values. If std_samples is equal to 1, this directive is neglected

# Optional
##########
print_average_ssr  .True.           # Optional directive to check the average SSR/NDF (See generated OUTPUT file)

#&input_parameters                   # The software was designed to define robust initial parameters for fitting based on the option of "what_to_fit" and
# A0 0.8                             # "fitting_function". Nevertheless, for cases where fittings fail to converge, the user can initialise the parameters. 
# A1 0.2                             # Depending on the option for "fitting_function" extra parameters need to be defined.
# A2 0.1 
#&end_input_parameters

plot_RAW_data     .True.            # Set to .False. to turn off the printing of the RAW_DATA file    (.True. by default)
plot_fittings     .True.            # Set to .False. to turn off the printing of the FITTED_DATA file (.True. by default)

